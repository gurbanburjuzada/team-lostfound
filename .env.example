# AI Provider (from topic-1)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Your app settings
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lostfound
IMAGE_STORAGE_DIR=./data/uploads
MAX_IMAGE_SIZE_MB=5
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
SEMAPHORE_LIMIT=5
CACHE_TTL_SECONDS=3600