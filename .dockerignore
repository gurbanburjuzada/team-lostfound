# .dockerignore — exclude files from Docker build context

# Git
.git/
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment files (don't leak secrets to image)
.env
.env.local
.env.*.local

# Local development
local_test/
temp/
tmp/
*.log

# Database
*.db
*.sqlite
*.sqlite3

# Other
node_modules/
.mypy_cache/
.dmypy.json
dmypy.json
